            ResponseMetrics: - View Detailed Metrics Button
            
            QuickActions: Quick Actions
            QuickActions: - Create New Ticket Button
            QuickActions: - View All Tickets Button
            QuickActions: - Knowledge Base Button
        }
        
        state NavigationTabs {
            HelpDeskTab: Help Desk Dashboard Tab
            TicketsTab: Support Tickets Tab
            KnowledgeBaseTab: Knowledge Base Tab
            ReportsTab: Support Reports Tab
            SettingsTab: Support Settings Tab
        }
    }
    
    state "Help Desk Dashboard" as HelpDeskDashboard {
        TicketOverview: Ticket Overview
