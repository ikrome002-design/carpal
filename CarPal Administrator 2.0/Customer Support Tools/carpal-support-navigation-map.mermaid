stateDiagram-v2
    [*] --> SupportPage
    
    state SupportPage {
        [*] --> SupportDashboard
        
        state SupportDashboard {
            TicketSummary: Ticket Summary
            TicketSummary: - New Tickets Count
            TicketSummary: - Open Tickets Count
            TicketSummary: - Resolved Tickets Count
            
            PriorityMetrics: Priority Metrics
            PriorityMetrics: - High Priority Count
            PriorityMetrics: - Medium Priority Count
            PriorityMetrics: - Low Priority Count
            
            ResponseMetrics: Response Metrics
