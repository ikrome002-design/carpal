stateDiagram-v2
    [*] --> Login
    Login --> Dashboard
    Dashboard --> ServiceHub: Click "Service Hub"
    
    %% Service Hub Main Page (Service History Records Removed)
    state ServiceHub {
        MainMenu: Service Hub Main Menu
        MainMenu: - Job Scheduling & Tracking
        MainMenu: - Customer Communication Tools
    }
    
    %% Job Scheduling & Tracking Section (Print/Download & View Completed Vehicles Removed)
    ServiceHub --> JobSchedulingTracking: Click "Job Scheduling & Tracking"
    state JobSchedulingTracking {
        JobDashboard: Job Dashboard
        JobDashboard: - View Jobs by Status (Scheduled/In Progress Only)
        JobDashboard: - Quick Filter Options (Status/Date/Technician)
        JobDashboard: - Search Bar (License Plate/Customer Name/Job ID)
        JobDashboard: - Sort Options (Date/Priority/Status)
        
        JobActions: Job Actions
        JobActions: - New Appointment Button (Create New Service Job)
        JobActions: - View Details Icon (Enhanced Job Information)
        JobActions: - Update Progress Button (Send Customer Updates)
        JobActions: - Edit Job Button (Modify Job Details)
        JobActions: - Assign Technician Button (Change Assignment)
    }
    
    %% New Appointment Flow
    JobSchedulingTracking --> NewAppointmentForm: Click "New Appointment"
    state NewAppointmentForm {
        AppointmentWizard: New Appointment Wizard
        
        CustomerInfo: Step 1: Customer Information
        CustomerInfo: - Full Name (Required)
        CustomerInfo: - Phone Number (Required)
        CustomerInfo: - Email Address (Optional)
        CustomerInfo: - Physical Address (Optional)
        CustomerInfo: - ID/Passport Number (Required)
        CustomerInfo: - Next Button
        
        VehicleInfo: Step 2: Vehicle Information
        VehicleInfo: - License Plate Number (Required)
        VehicleInfo: - Vehicle Make & Model (Required)
        VehicleInfo: - Year of Manufacture (Required)
        VehicleInfo: - Engine Number (Optional)
        VehicleInfo: - Chassis Number (Optional)
        VehicleInfo: - Vehicle Color (Required)
        VehicleInfo: - Mileage Reading (Required)
        VehicleInfo: - Previous/Next Buttons
        
        ServiceDetails: Step 3: Service Details
        ServiceDetails: - Service Type Selection (Dropdown)
        ServiceDetails: - Problem Description (Text Area)
        ServiceDetails: - Urgency Level (Low/Medium/High)
        ServiceDetails: - Estimated Duration (Hours/Days)
        ServiceDetails: - Special Instructions (Optional)
        ServiceDetails: - Previous/Next Buttons
        
        AppointmentDetails: Step 4: Appointment Scheduling
        AppointmentDetails: - Preferred Date Picker
        AppointmentDetails: - Time Slot Selection
        AppointmentDetails: - Assign Technician (Dropdown)
        AppointmentDetails: - Alternative Date Options
        AppointmentDetails: - Previous/Next Buttons
        
        CommunicationPrefs: Step 5: Communication Preferences
        CommunicationPrefs: - SMS Notifications (Checkbox)
        CommunicationPrefs: - Email Notifications (Checkbox)
        CommunicationPrefs: - WhatsApp Updates (Checkbox)
        CommunicationPrefs: - Call Preferences (Checkbox)
        CommunicationPrefs: - Previous/Submit Buttons
    }
    
    NewAppointmentForm --> AppointmentConfirmation: Click "Submit Appointment"
    state AppointmentConfirmation {
        ConfirmationPage: Appointment Confirmation Page
        ConfirmationSuccess: ✓ Appointment Successfully Created
        ConfirmationSuccess: - Unique Job ID Generated & Displayed
        ConfirmationSuccess: - Customer Notification Sent (SMS/Email)
        ConfirmationSuccess: - Added to Technician Schedule
        ConfirmationSuccess: - Calendar Entry Created
        ConfirmationSuccess: - Print Appointment Slip Option
        ConfirmationSuccess: - Email Confirmation Copy Option
        ConfirmationSuccess: - Return to Dashboard Button
        ConfirmationSuccess: - Create Another Appointment Button
    }
    
    AppointmentConfirmation --> JobSchedulingTracking: Click "Return to Job Scheduling"
    AppointmentConfirmation --> NewAppointmentForm: Click "Create Another Appointment"
    
    %% Enhanced View Details Flow
    JobSchedulingTracking --> DetailedJobView: Click "View Details" Icon
    state DetailedJobView {
        JobDetailsPopup: Enhanced Job Details Popup Window
        DetailsTabs: Navigation Tabs
        DetailsTabs: - 1. Details Tab (Job Information)
        DetailsTabs: - 2. Billing Information Tab
        DetailsTabs: - 3. Assessment Form Tab
        DetailsTabs: - 4. Repair Images Tab
        DetailsTabs: - 5. Supporting Documents Tab
        DetailsTabs: - 6. Technician Notes Tab
        DetailsTabs: - Close Popup Button (X)
    }
    
    %% Details Tab
    DetailedJobView --> DetailsTab: Click "Details" Tab (Default Active)
    state DetailsTab {
        DetailsLayout: Details Tab Layout
        
        CustomerSection: Customer Information Section
        CustomerSection: - Full Name (View/Edit with OTP)
        CustomerSection: - Phone Number (View/Edit with OTP)
        CustomerSection: - Email Address (View/Edit with OTP)
        CustomerSection: - Physical Address (View/Edit with OTP)
        CustomerSection: - ID Number (View Only)
        CustomerSection: - Edit Customer Info Button
        
        ServiceSection: Service Information Section
        ServiceSection: - Service Type (View/Edit/Remove)
        ServiceSection: - Problem Description (View/Edit/Remove)
        ServiceSection: - Urgency Level (View/Edit)
        ServiceSection: - Current Status (View/Edit)
        ServiceSection: - Assigned Technician (View/Change)
        ServiceSection: - Edit Service Info Button
        
        VehicleSection: Vehicle Information Section
        VehicleSection: - License Plate (View/Edit with OTP)
        VehicleSection: - Make & Model (View/Edit with OTP)
        VehicleSection: - Year (View/Edit with OTP)
        VehicleSection: - Color (View/Edit with OTP)
        VehicleSection: - Mileage (View/Edit with OTP)
        VehicleSection: - Edit Vehicle Info Button
        
        ActionButtons: Section Action Buttons
        ActionButtons: - Save All Changes Button
        ActionButtons: - Cancel Changes Button
        ActionButtons: - Reset Form Button
    }
    
    DetailsTab --> OTPVerification: Click "Edit Customer Info" or "Edit Vehicle Info"
    state OTPVerification {
        OTPModal: OTP Verification Modal
        OTPForm: OTP Authorization Process
        OTPForm: - Vehicle Owner Phone Number Display
        OTPForm: - Send OTP Code Button
        OTPForm: - OTP Code Input Field (6 digits)
        OTPForm: - Resend OTP Button (60s cooldown)
        OTPForm: - Verify OTP Button
        OTPForm: - Cancel Authorization Button
        OTPForm: - OTP Expiry Timer (5 minutes)
        
        OTPStatus: Verification Status
        OTPStatus: - Success: "Authorization Granted - Edit Mode Enabled"
        OTPStatus: - Error: "Invalid OTP - Please Try Again"
        OTPStatus: - Expired: "OTP Expired - Request New Code"
    }
    
    OTPVerification --> DetailsTab: Click "Verify OTP" (Success)
    OTPVerification --> DetailsTab: Click "Cancel Authorization"
    DetailsTab --> DetailedJobView: Click "Back to Tabs"
    
    %% Billing Information Tab
    DetailedJobView --> BillingTab: Click "Billing Information" Tab
    state BillingTab {
        BillingLayout: Billing Information Layout
        
        ServiceCharges: Service Charges Section
        ServiceCharges: - Labor Cost (Editable)
        ServiceCharges: - Service Fee (Editable)
        ServiceCharges: - Diagnostic Fee (Editable)
        ServiceCharges: - Additional Services (Add/Remove)
        
        PartsCharges: Parts & Materials Section
        PartsCharges: - Parts List (Add/Edit/Remove)
        PartsCharges: - Part Name & Quantity
        PartsCharges: - Unit Price & Total
        PartsCharges: - Supplier Information
        
        PlatformCharges: CarPal Platform Charges
        PlatformCharges: - Platform Fee (Auto-calculated 5%)
        PlatformCharges: - SMS Charges (Auto-tracked)
        PlatformCharges: - Processing Fee (Fixed Rate)
        PlatformCharges: - Total Platform Charges
        
        TaxCalculations: Tax & Total Section
        TaxCalculations: - Subtotal Before Tax
        TaxCalculations: - VAT (16% Auto-calculated)
        TaxCalculations: - Service Tax (2% Auto-calculated)
        TaxCalculations: - Final Total Amount
        
        BillingActions: Billing Actions
        BillingActions: - Edit Billing Information Button
        BillingActions: - Add Parts/Services Button
        BillingActions: - Generate Invoice Preview Button
        BillingActions: - Save Billing Changes Button
        BillingActions: - Print Estimate Button
    }
    
    BillingTab --> DetailedJobView: Click "Back to Tabs"
    
    %% Assessment Form Tab
    DetailedJobView --> AssessmentTab: Click "Assessment Form" Tab
    state AssessmentTab {
        AssessmentLayout: Assessment Form Layout
        
        InitialAssessment: Initial Vehicle Assessment
        InitialAssessment: - Check-in Date & Time
        InitialAssessment: - Receiving Technician Name
        InitialAssessment: - Vehicle Exterior Condition
        InitialAssessment: - Vehicle Interior Condition
        InitialAssessment: - Engine Bay Inspection Notes
        InitialAssessment: - Fuel Level & Mileage Record
        
        TechnicianUpdates: Technician Assessment Updates
        TechnicianUpdates: - Diagnostic Results
        TechnicianUpdates: - Problem Identification
        TechnicianUpdates: - Required Repairs List
        TechnicianUpdates: - Parts Needed
        TechnicianUpdates: - Estimated Completion Time
        TechnicianUpdates: - Work Progress Updates
        
        DamageDocumentation: Damage Documentation
        DamageDocumentation: - Pre-existing Damage Notes
        DamageDocumentation: - New Issues Discovered
        DamageDocumentation: - Severity Assessment
        DamageDocumentation: - Photo Reference Numbers
        
        RepairRecommendations: Repair Recommendations
        RepairRecommendations: - Primary Repairs (Required)
        RepairRecommendations: - Secondary Repairs (Recommended)
        RepairRecommendations: - Optional Improvements
        RepairRecommendations: - Cost Implications
        
        AssessmentActions: Assessment Actions
        AssessmentActions: - View Complete Assessment Button
        AssessmentActions: - Edit Assessment Button (OTP Required)
        AssessmentActions: - Print Assessment Report Button
        AssessmentActions: - Export Assessment PDF Button
    }
    
    AssessmentTab --> OTPVerificationAssessment: Click "Edit Assessment"
    state OTPVerificationAssessment {
        AssessmentOTPModal: Assessment Edit Authorization Modal
        AssessmentOTP: Vehicle Owner OTP Verification
        AssessmentOTP: - Authorization Required Message
        AssessmentOTP: - Vehicle Owner Contact Display
        AssessmentOTP: - Send OTP Button
        AssessmentOTP: - OTP Input Field
        AssessmentOTP: - Verify & Allow Edit Button
        AssessmentOTP: - Cancel Edit Request Button
        AssessmentOTP: - Edit Reason Selection (Dropdown)
    }
    
    OTPVerificationAssessment --> AssessmentTab: Click "Verify & Allow Edit"
    AssessmentTab --> DetailedJobView: Click "Back to Tabs"
    
    %% Repair Images Tab
    DetailedJobView --> RepairImagesTab: Click "Repair Images" Tab
    state RepairImagesTab {
        ImageGalleryLayout: Repair Images Gallery Layout
        
        ImageCategories: Image Organization Categories
        ImageCategories: - Before Repair Images (Red Border)
        ImageCategories: - During Repair Images (Yellow Border)
        ImageCategories: - After Repair Images (Green Border)
        ImageCategories: - Category Filter Buttons
        ImageCategories: - View All Images Button
        
        ImageGrid: Image Display Grid
        ImageGrid: - Thumbnail Grid View
        ImageGrid: - Image Title & Description
        ImageGrid: - Upload Date & Time
        ImageGrid: - Technician Name
        ImageGrid: - Click to Enlarge Images
        ImageGrid: - Download Individual Image
        
        ImageActions: Image Management Actions
        ImageActions: - Upload New Images Button
        ImageActions: - Bulk Select Images Checkbox
        ImageActions: - Delete Selected Images Button
        ImageActions: - Rearrange Images Button
        ImageActions: - Export All Images ZIP
        
        ImageDetails: Selected Image Details Panel
        ImageDetails: - Full Size Image Display
        ImageDetails: - Image Properties (Size/Format/Date)
        ImageDetails: - Edit Image Description
        ImageDetails: - Change Image Category
        ImageDetails: - Delete This Image Button
    }
    
    RepairImagesTab --> ImageUpload: Click "Upload New Images"
    state ImageUpload {
        ImageUploadModal: Image Upload Modal Window
        UploadForm: Multi-Image Upload Form
        UploadForm: - Drag & Drop Upload Area
        UploadForm: - Browse Files Button (Multi-select)
        UploadForm: - Supported Formats (JPG/PNG/HEIC/WebP)
        UploadForm: - Max File Size (10MB per image)
        UploadForm: - Preview Selected Images
        
        CategorySelection: Image Categorization
        CategorySelection: - Before Repair Radio Button
        CategorySelection: - During Repair Radio Button  
        CategorySelection: - After Repair Radio Button
        CategorySelection: - Apply to All Images Checkbox
        
        ImageDescriptions: Individual Image Details
        ImageDescriptions: - Image Description Text Field
        ImageDescriptions: - Add Description to Each Image
        ImageDescriptions: - Auto-generate Timestamps
        ImageDescriptions: - Technician Name Auto-fill
        
        UploadActions: Upload Actions
        UploadActions: - Upload All Images Button
        UploadActions: - Cancel Upload Button
        UploadActions: - Upload Progress Bar
        UploadActions: - Success/Error Messages
    }
    
    ImageUpload --> RepairImagesTab: Click "Upload Complete" or "Cancel"
    RepairImagesTab --> DetailedJobView: Click "Back to Tabs"
    
    %% Supporting Documents Tab
    DetailedJobView --> SupportingDocsTab: Click "Supporting Documents" Tab
    state SupportingDocsTab {
        DocumentsLayout: Supporting Documents Layout
        
        RequiredDocs: Required Supporting Documents Checklist
        RequiredDocs: ✓/✗ Insurance Claim Form (PDF/Word)
        RequiredDocs: ✓/✗ Police Abstract Report (PDF)
        RequiredDocs: ✓/✗ Vehicle Inspection Report (PDF/Word)
        RequiredDocs: ✓/✗ Repair Estimate/Assessment Report (PDF)
        RequiredDocs: ✓/✗ Vehicle Damage Photographs (Images/PDF)
        RequiredDocs: ✓/✗ Copy of Vehicle Logbook (PDF/Image)
        RequiredDocs: ✓/✗ Driver's Valid License (PDF/Image)
        RequiredDocs: ✓/✗ Insurance Premium Payment Proof (PDF/Image)
        RequiredDocs: ✓/✗ Excess Payment Receipt (PDF/Image)
        RequiredDocs: - Completion Status Bar
        
        OptionalDocs: Optional Supporting Documents
        OptionalDocs: - ETR Receipts for Parts/Services (PDF)
        OptionalDocs: - Vehicle Valuation Certificate (PDF)
        OptionalDocs: - Signed Work Completion Form (PDF/Image)
        OptionalDocs: - Additional Insurance Documents (PDF)
        OptionalDocs: - Warranty Information (PDF/Image)
        
        DocumentGrid: Documents Display Grid
        DocumentGrid: - Document Thumbnails
        DocumentGrid: - Document Name & Type
        DocumentGrid: - Upload Date & Size
        DocumentGrid: - Status Indicators
        DocumentGrid: - View/Download/Delete Buttons
        
        DocActions: Document Management Actions
        DocActions: - Upload Document Button (Multi-type)
        DocActions: - Bulk Upload ZIP Button
        DocActions: - Export All Documents Button
        DocActions: - Check Completeness Button
        DocActions: - Generate Document Report Button
    }
    
    SupportingDocsTab --> DocUpload: Click "Upload Document"
    state DocUpload {
        DocUploadModal: Document Upload Modal
        DocUploadForm: Document Upload Form
        DocUploadForm: - Document Type Selection (Dropdown)
        DocUploadForm: - Required/Optional Indicator
        DocUploadForm: - Choose File Button
        DocUploadForm: - Supported Formats (PDF/Word/MP4/Images)
        DocUploadForm: - Max File Size (50MB)
        DocUploadForm: - Document Preview Panel
        
        DocMetadata: Document Information
        DocMetadata: - Document Description (Text Area)
        DocMetadata: - Document Date (Date Picker)
        DocMetadata: - Issuing Authority (Text Field)
        DocMetadata: - Reference Number (Text Field)
        DocMetadata: - Expiry Date (If Applicable)
        
        UploadProgress: Upload Process
        UploadProgress: - Upload Progress Bar
        UploadProgress: - File Validation Status
        UploadProgress: - Upload Success/Error Messages
        UploadProgress: - Upload Another Document Option
        UploadProgress: - Complete Upload Button
    }
    
    DocUpload --> SupportingDocsTab: Click "Upload Complete"
    SupportingDocsTab --> DetailedJobView: Click "Back to Tabs"
    
    %% Technician Notes Tab
    DetailedJobView --> TechNotesTab: Click "Technician Notes" Tab
    state TechNotesTab {
        NotesLayout: Technician Notes Layout
        
        NotesHistory: Chronological Notes History
        NotesHistory: - Notes Timeline (Latest First)
        NotesHistory: - Technician Name & Photo
        NotesHistory: - Date & Time Stamps
        NotesHistory: - Note Content & Attachments
        NotesHistory: - Note Priority Indicators
        NotesHistory: - Reply/Comment Options
        
        NotesFilter: Notes Filter Options
        NotesFilter: - Filter by Technician
        NotesFilter: - Filter by Date Range
        NotesFilter: - Filter by Priority Level
        NotesFilter: - Search Notes Content
