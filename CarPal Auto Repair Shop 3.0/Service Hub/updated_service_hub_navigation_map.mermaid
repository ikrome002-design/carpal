        NotesActions: Notes Management Actions
        NotesActions: - Add New Note Button
        NotesActions: - Export Notes Report Button
        NotesActions: - Print All Notes Button
        NotesActions: - Archive Old Notes Button
        
        ActiveNote: Selected Note Details
        ActiveNote: - Full Note Content Display
        ActiveNote: - Attached Files List
        ActiveNote: - Edit Note Button (Own Notes Only)
        ActiveNote: - Delete Note Button (Own Notes Only)
        ActiveNote: - Reply to Note Button
    }
    
    TechNotesTab --> AddTechNote: Click "Add New Note"
    state AddTechNote {
        NoteCreationModal: Add Technician Note Modal
        NoteForm: New Note Creation Form
        NoteForm: - Note Title (Text Field)
        NoteForm: - Note Content (Rich Text Editor)
        NoteForm: - Priority Level Selection (Low/Medium/High/Critical)
        NoteForm: - Attach Files Button (Multiple Files)
