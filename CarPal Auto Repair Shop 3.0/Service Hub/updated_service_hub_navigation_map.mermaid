        NotePreview: Note Preview Section
        NotePreview: - Preview Note Formatting
        NotePreview: - Preview Attachments
        NotePreview: - Character Count
        NotePreview: - Estimated Reading Time
        
        NoteSubmission: Note Submission
        NoteSubmission: - Save as Draft Button
        NoteSubmission: - Save & Notify Team Button
        NoteSubmission: - Save Private Note Button
        NoteSubmission: - Cancel Note Button
        NoteSubmission: - Auto-save Indicator
    }
    
    AddTechNote --> TechNotesTab: Click "Save Note"
    TechNotesTab --> DetailedJobView: Click "Back to Tabs"
    DetailedJobView --> JobSchedulingTracking: Click "Close Details Popup (X)"
    
    %% Update Progress Flow
    JobSchedulingTracking --> UpdateProgressForm: Click "Update Progress"
    state UpdateProgressForm {
        ProgressUpdateModal: Progress Update Modal Window
        ProgressUpdate: Customer Progress Update Form
        
        VehicleSelection: Vehicle Identification
        VehicleSelection: - Enter Vehicle License Plate
        VehicleSelection: - Auto-complete Suggestions
        VehicleSelection: - Verify Vehicle Details
        VehicleSelection: - Customer Contact Info Display
        
        UpdateTemplates: Update Message Templates
        UpdateTemplates: - Template Selection Dropdown
        UpdateTemplates: - "Work Started" Template
        UpdateTemplates: - "Progress Update" Template  
        UpdateTemplates: - "Waiting for Parts" Template
        UpdateTemplates: - "Quality Check" Template
        UpdateTemplates: - "Almost Complete" Template
        UpdateTemplates: - Custom Message Option
        
        MessageCustomization: Message Customization
        MessageCustomization: - Template Preview
        MessageCustomization: - Edit Message Content
        MessageCustomization: - Add Personal Note
        MessageCustomization: - Include ETA Option
        MessageCustomization: - Attach Images Option
        
        DeliveryOptions: Delivery Method Selection
        DeliveryOptions: - SMS Notification Checkbox
        DeliveryOptions: - Email Notification Checkbox
        DeliveryOptions: - WhatsApp Message Checkbox
        DeliveryOptions: - Call After Send Checkbox
        DeliveryOptions: - Send Preview Button
        DeliveryOptions: - Send Update Button
    }
    
    UpdateProgressForm --> CustomerNotification: Click "Send Update"
    state CustomerNotification {
        NotificationStatus: Update Delivery Status
        NotificationSent: ✓ Update Successfully Sent
        NotificationSent: - SMS Delivery Status & Timestamp
        NotificationSent: - Email Delivery Status & Timestamp
        NotificationSent: - WhatsApp Delivery Status
