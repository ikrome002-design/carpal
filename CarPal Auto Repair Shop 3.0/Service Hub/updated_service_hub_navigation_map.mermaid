        BillingTracking: - Email Delivery (Free)
        BillingTracking: - WhatsApp Charges (If Applicable)
        BillingTracking: - Total Communication Costs
    }
    
    CustomerNotification --> JobSchedulingTracking: Click "Return to Job Scheduling"
    
