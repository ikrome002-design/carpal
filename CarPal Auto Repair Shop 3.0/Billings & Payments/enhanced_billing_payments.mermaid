    %% Style Definitions
    classDef primary fill:#2563eb,stroke:#1e40af,color:white
    classDef secondary fill:#3b82f6,stroke:#2563eb,color:white
    classDef decision fill:#dbeafe,stroke:#3b82f6,color:black
    classDef action fill:#10b981,stroke:#047857,color:white
    classDef popup fill:#34d399,stroke:#10b981,color:black
    classDef payment fill:#f59e0b,stroke:#d97706,color:white
    classDef warning fill:#ef4444,stroke:#b91c1c,color:white
    classDef billing fill:#8b5cf6,stroke:#7c3aed,color:white
    classDef download fill:#06b6d4,stroke:#0891b2,color:white
    classDef email fill:#f97316,stroke:#ea580c,color:white
    
    %% Apply Styles
    class Dashboard,BillingPayments primary
    class MainNav,MainTabs,InvoiceActions,PlatformInvoiceActions,RefundRequestStatus,RefundRequestActions,ReportTypes decision
    class HeaderActions,DownloadPurposeOptions,EmailPurposeOptions decision
    class CustomerBillings,CarPalBillings,Refunds,ReportsAnalytics,PaymentHistory secondary
    class ViewInvoice,PayNow,GenerateInvoiceButton,SubmitRefundButton,AddServiceButton,SendReminderButton action
    class MarkAsPaid,ApproveRefund,RejectRefund,EmailToCustomer action
    class NotificationsPopup,UserMenu,InvoiceDetailView,PaymentDetailsForm,ReminderOptions,RefundApprovalForm popup
    class RefundRejectionForm,InvoiceSuccess,RefundSuccess,PaymentConfirmed,PaymentFailed,RejectionConfirmation popup
    class DownloadPurposeSelection,EmailPurposeSelection,GeneralDownloadOptions,GeneralEmailOptions popup
    class MPesaPayment,PaymentVerification,ProcessRefund payment
    class OutstandingAmount,ServiceChargeCalculation,PaymentFailed warning
    class BillingPurposeDownload,BillingDownloadOptions,BillingDownloadProcessing,BillingDownloadComplete billing
    class BillingPurposeEmail,BillingEmailOptions,BillingEmailProcessing,BillingEmailSent billing
    class DownloadInvoice,GeneralPurposeDownload,GeneralDownloadButton,DownloadFile download
    class EmailInvoice,GeneralPurposeEmail,SendGeneralEmailButton,GeneralEmailSent email