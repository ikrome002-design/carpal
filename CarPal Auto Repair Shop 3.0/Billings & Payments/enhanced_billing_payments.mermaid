graph TD
    %% Main Layout Structure
    Dashboard["Dashboard"] --> MainNav{Main Navigation}
    MainNav --> BillingPayments["Billing & Payments"]
    
    %% Header Actions
    BillingPayments --> HeaderActions{"Header Actions"}
    HeaderActions --> Notifications["Notifications Icon"]
    Notifications --> |"Click"| NotificationsPopup["Notifications Window"]
    NotificationsPopup --> PaymentAlerts["Payment Alerts"]
    NotificationsPopup --> InvoiceReminders["Invoice Reminders"]
    NotificationsPopup --> SystemUpdates["System Updates"]
    
    HeaderActions --> UserProfile["User Profile"]
    UserProfile --> |"Click"| UserMenu["User Menu Popup"]
    UserMenu --> ProfileSettings["Profile Settings"]
    UserMenu --> LogOut["Log Out"]
    
    %% Main Navigation Tabs
    BillingPayments --> MainTabs{"Main Tabs"}
    MainTabs --> CustomerBillings["Customer Billings"]
    MainTabs --> CarPalBillings["CarPal Billings"]
    MainTabs --> Refunds["Refunds"]
    
    %% Customer Billings Section
    CustomerBillings --> CustomerSummary["Summary Cards"]
    CustomerSummary --> TotalInvoices["Total Invoices"]
    CustomerSummary --> TotalAmountBilled["Total Amount Billed"]
    CustomerSummary --> TotalPaymentsReceived["Total Payments Received"]
    CustomerSummary --> OutstandingAmount["Outstanding Amount"]
    
    CustomerBillings --> InvoiceOverview["Recent Invoices Table"]
    InvoiceOverview --> InvoiceActions{"Invoice Actions"}
    InvoiceActions --> ViewInvoice["View Invoice"]
    ViewInvoice --> |"Click"| InvoiceDetailView["Invoice Detail View"]
    InvoiceDetailView --> InvoiceItems["Service Items & Charges"]
    InvoiceDetailView --> CustomerDetails["Customer Information"]
    InvoiceDetailView --> ServiceChargeBreakdown["Service Charge Breakdown"]
    InvoiceDetailView --> InvoiceActionButtons["Action Buttons"]
    
    %% Enhanced Download Feature with Billing Purpose Integration
    InvoiceActionButtons --> DownloadInvoice["Download Invoice Button"]
    DownloadInvoice --> |"Click"| DownloadPurposeSelection["Download Purpose Selection Popup"]
    
    DownloadPurposeSelection --> DownloadPurposeOptions{"Select Download Purpose"}
    DownloadPurposeOptions --> GeneralPurposeDownload["General Purpose"]
    DownloadPurposeOptions --> BillingPurposeDownload["Billing Purpose"]
    
    %% General Purpose Download Path
    GeneralPurposeDownload --> |"Click"| GeneralDownloadOptions["General Purpose Download Options"]
    GeneralDownloadOptions --> GeneralDocumentSelection["Document Selection Options"]
    GeneralDocumentSelection --> SelectInvoiceOnly["Invoice Only Checkbox"]
    GeneralDocumentSelection --> SelectServiceHistory["Service History Checkbox"]
    GeneralDocumentSelection --> SelectSupportingDocs["Supporting Documents Checkbox"]
    GeneralDocumentSelection --> SelectTimePeriod["Time Period Selection"]
    GeneralDownloadOptions --> GeneralWatermarkSettings["Watermark Settings"]
    GeneralWatermarkSettings --> EnableWatermark["Generate with Watermark Checkbox (Auto-checked)"]
    GeneralWatermarkSettings --> WatermarkText["Watermark Text: 'Not For Billing Purposes - www.carpal.ke. A Product of Citrus Labs Limited.'"]
    GeneralDownloadOptions --> GeneralDownloadButton["Generate General Download Button"]
    GeneralDownloadButton --> |"Click"| GeneralDownloadProcessing["Processing General Download"]
    GeneralDownloadProcessing --> GeneralDownloadComplete["General Download Complete"]
    GeneralDownloadComplete --> DownloadFile["Download File to Device"]
    
    %% Billing Purpose Download Path  
    BillingPurposeDownload --> |"Click"| BillingDownloadOptions["Billing Purpose Download Options"]
    BillingDownloadOptions --> BillingDocumentSettings["Billing Document Settings"]
    BillingDocumentSettings --> MostRecentServiceOnly["Most Recent Service History Only (Auto-selected)"]
    BillingDocumentSettings --> AutoGenerateInvoice["Auto-generate CarPal Invoice as Front Page (Auto-enabled)"]
    BillingDocumentSettings --> IncludeAllSupportingDocs["Include All Required Supporting Documents (Auto-enabled)"]
    BillingDocumentSettings --> NoWatermark["No Watermark Applied (Auto-disabled)"]
    BillingDownloadOptions --> BillingNotificationSettings["Notification Settings"]
    BillingNotificationSettings --> NotifyVehicleOwner["Notify Vehicle Owner via Email Checkbox"]
    BillingNotificationSettings --> EmailNotificationText["Email Notification Message Preview"]
    BillingDownloadOptions --> BillingDownloadButton["Generate Billing Download Button"]
    BillingDownloadButton --> |"Click"| BillingDownloadProcessing["Processing Billing Download"]
    BillingDownloadProcessing --> AutoInvoiceGeneration["Auto-generate CarPal Invoice"]
    AutoInvoiceGeneration --> CompileSupportingDocs["Compile All Supporting Documents"]
    CompileSupportingDocs --> CreateBillingPDF["Create Billing Purpose PDF"]
    CreateBillingPDF --> BillingDownloadComplete["Billing Download Complete"]
    BillingDownloadComplete --> DownloadBillingFile["Download Billing File to Device"]
    BillingDownloadComplete --> SendEmailNotification["Send Email Notification (if enabled)"]
    SendEmailNotification --> EmailDeliveryConfirmation["Email Delivery Confirmation"]
    
    %% Enhanced Email Invoice Feature with Billing Purpose Integration
    InvoiceActionButtons --> EmailInvoice["Email Invoice Button"]
    EmailInvoice --> |"Click"| EmailPurposeSelection["Email Purpose Selection Popup"]
    
    EmailPurposeSelection --> EmailPurposeOptions{"Select Email Purpose"}
    EmailPurposeOptions --> GeneralPurposeEmail["General Purpose Email"]
    EmailPurposeOptions --> BillingPurposeEmail["Billing Purpose Email"]
    
    %% General Purpose Email Path
    GeneralPurposeEmail --> |"Click"| GeneralEmailOptions["General Purpose Email Options"]
    GeneralEmailOptions --> GeneralEmailDocuments["Email Document Selection"]
    GeneralEmailDocuments --> EmailInvoiceOnly["Invoice Only Checkbox"]
    GeneralEmailDocuments --> EmailServiceHistory["Service History Checkbox"]
    GeneralEmailDocuments --> EmailSupportingDocs["Supporting Documents Checkbox"]
    GeneralEmailOptions --> GeneralEmailSettings["General Email Settings"]
    GeneralEmailSettings --> RecipientEmail["Recipient Email Address Input"]
    GeneralEmailSettings --> EmailSubjectGeneral["Email Subject Input"]
    GeneralEmailSettings --> EmailBodyGeneral["Email Body Textarea"]
    GeneralEmailSettings --> GeneralWatermarkEmail["Apply Watermark Checkbox (Auto-checked)"]
    GeneralEmailOptions --> SendGeneralEmailButton["Send General Email Button"]
    SendGeneralEmailButton --> |"Click"| GeneralEmailProcessing["Processing General Email"]
    GeneralEmailProcessing --> GeneralEmailSent["General Email Sent Successfully"]
    GeneralEmailSent --> GeneralEmailConfirmation["Email Delivery Confirmation"]
    
    %% Billing Purpose Email Path
    BillingPurposeEmail --> |"Click"| BillingEmailOptions["Billing Purpose Email Options"]
    BillingEmailOptions --> BillingEmailDocuments["Billing Email Document Settings"]
    BillingEmailDocuments --> BillingEmailMostRecent["Most Recent Service History Only (Auto-selected)"]
    BillingEmailDocuments --> BillingEmailAutoInvoice["Auto-generate CarPal Invoice as Front Page (Auto-enabled)"]
    BillingEmailDocuments --> BillingEmailAllDocs["Include All Required Supporting Documents (Auto-enabled)"]
    BillingEmailDocuments --> BillingEmailNoWatermark["No Watermark Applied (Auto-disabled)"]
    BillingEmailOptions --> BillingEmailSettings["Billing Email Settings"]
    BillingEmailSettings --> BillingRecipientEmail["Vehicle Owner Email Address (Auto-populated)"]
    BillingEmailSettings --> BillingEmailSubject["Email Subject: 'Official Billing Documentation - [Vehicle License Plate]' (Auto-generated)"]
    BillingEmailSettings --> BillingEmailBody["Email Body Template (Auto-populated)"]
    BillingEmailBody --> EmailTemplateText["Template: Professional billing documentation with service completion notice"]
    BillingEmailSettings --> CCRecipients["CC Recipients (Optional)"]
    BillingEmailSettings --> BillingEmailPriority["Email Priority: High (Auto-set)"]
    BillingEmailOptions --> SendBillingEmailButton["Send Billing Email Button"]
    SendBillingEmailButton --> |"Click"| BillingEmailProcessing["Processing Billing Email"]
    BillingEmailProcessing --> BillingAutoInvoiceGeneration["Auto-generate CarPal Invoice"]
    BillingAutoInvoiceGeneration --> BillingCompileDocs["Compile All Supporting Documents"]
    BillingCompileDocs --> BillingCreatePDF["Create Billing Purpose PDF"]
    BillingCreatePDF --> BillingEmailSent["Billing Email Sent Successfully"]
    BillingEmailSent --> BillingEmailDeliveryConfirm["Email Delivery Confirmation"]
    BillingEmailSent --> LogBillingEmail["Log Email in Customer Communication History"]
    
    %% Return paths for Download flows
    GeneralDownloadComplete --> InvoiceDetailView
    BillingDownloadComplete --> InvoiceDetailView
    EmailDeliveryConfirmation --> InvoiceDetailView
    
    %% Return paths for Email flows
    GeneralEmailConfirmation --> InvoiceDetailView
    BillingEmailDeliveryConfirm --> InvoiceDetailView
    LogBillingEmail --> InvoiceDetailView
    
    %% Original Action Buttons Continue
    InvoiceActionButtons --> MarkAsPaid["Mark as Paid Button"]
