graph TD
    %% Main Sections
    Login[Login] --> Dashboard
    Dashboard --> |"Main Navigation"| MainNav{Main Navigation}
    
    %% Main Navigation Branches
    MainNav --> ServiceHub["Service Hub"]
    MainNav --> VehicleCheckin["Vehicle Check-In"]
    MainNav --> BillingPayments["Billing & Payments"]
    MainNav --> VehicleHistory["Vehicle History"]
    MainNav --> Settings["Settings"]
    MainNav --> VehicleCheckout["Vehicle Check-Out"]
    MainNav --> Inventory["Inventory"]

    %% Service Hub Section
    ServiceHub --> JobScheduling["Job Scheduling & Tracking"]
    ServiceHub --> ServiceRecords["Service History Records"]
    ServiceHub --> CustomerComm["Customer Communication Tools"]
    
    JobScheduling --> |"Features"| JobFeatures{"Job Features"}
    JobFeatures --> NewAppt["New Appointment"]
    JobFeatures --> TrackJobs["Track Jobs"]
    JobFeatures --> UpdateProgress["Update Progress"]

    %% Vehicle Check-In Section
    VehicleCheckin --> CheckInOptions{"Vehicle Type"}
    CheckInOptions --> NewVehicle["New Vehicle"]
    CheckInOptions --> ExistingVehicle["Existing Vehicle"]
    
    NewVehicle & ExistingVehicle --> AssessmentForm["Assessment Form"]
    AssessmentForm --> Components{"Components Check"}
    Components --> AudioComp["Audio Components"]
    Components --> InteriorComp["Interior Components"]
    Components --> ExteriorComp["Exterior Components"]
    Components --> EngineComp["Engine Components"]

    %% Billing & Payments Section
    BillingPayments --> InvoiceGen["Invoice Generation"]
    BillingPayments --> PaymentMgmt["Payment Management"]
    BillingPayments --> Reports["Financial Reports"]
    
    InvoiceGen --> ServiceCharge["Service Charge Calculation"]
    PaymentMgmt --> MPesa["M-Pesa Integration"]
    
    %% Settings Section
    Settings --> UserType{"User Type"}
    UserType --> AdminSettings["Administrator Settings"]
    UserType --> StaffSettings["Staff Settings"]
    
    AdminSettings --> AdminFeatures{"Admin Features"}
    AdminFeatures --> StaffMgmt["Staff Management"]
    AdminFeatures --> PaymentInteg["Payment Integration"]
    AdminFeatures --> InsuranceContacts["Insurance Company Contacts"]
    AdminFeatures --> ServiceChargeConfig["Service Charge Configuration"]
    
    StaffSettings --> StaffFeatures{"Staff Features"}
    StaffFeatures --> ProfileSettings["Profile Settings"]
    StaffFeatures --> SupportHelp["Support & Help"]
    StaffFeatures --> SystemPrefs["System Preferences"]

    %% Vehicle Check-Out Section
    VehicleCheckout --> CheckOutForm["Check-Out Form"]
    CheckOutForm --> PostRepair["Post-Repair Assessment"]
    PostRepair --> Notifications["Customer Notifications"]
    
    %% Inventory Management Section
    Inventory --> InventoryDashboard["Inventory Dashboard"]
    
    %% Inventory List Management
    InventoryDashboard --> InventoryList["Inventory List"]
    InventoryList --> AddItem["Add New Item"]
    AddItem --> ItemDetailsForm["Item Details Form"]
    ItemDetailsForm --> ItemNameInput["Name Input"]
    ItemDetailsForm --> ItemCategoryInput["Category Input"]
    ItemDetailsForm --> ItemQuantityInput["Quantity Input"]
    ItemDetailsForm --> ItemThresholdInput["Low Stock Threshold"]
    ItemDetailsForm --> SaveItemButton["Save Item"]
    
    InventoryList --> EditItem["Edit Item"]
    EditItem --> UpdateItemForm["Update Item Form"]
    UpdateItemForm --> UpdateDetails["Update Details"]
    UpdateItemForm --> SaveChangesButton["Save Changes"]
    
    InventoryList --> RemoveItem["Remove Item"]
    RemoveItem --> DeleteConfirmation["Confirmation Dialog"]
    DeleteConfirmation --> ConfirmDelete["Confirm Delete"]
    
    %% Quantity Tracking
    InventoryDashboard --> StockLevels["Stock Levels"]
    StockLevels --> CurrentStockView["Current Stock View"]
    StockLevels --> LowStockAlerts["Low Stock Alerts"]
    LowStockAlerts --> AlertsList["Alerts List"]
    AlertsList --> MarkAlertReviewed["Mark as Reviewed"]
    
    %% Usage Logging
    InventoryDashboard --> UsageLogging["Usage Logging"]
    UsageLogging --> AutomaticDeduction["Automatic Deduction"]
    UsageLogging --> ManualAdjustment["Manual Adjustment"]
    ManualAdjustment --> AdjustmentForm["Adjustment Form"]
    AdjustmentForm --> SelectItem["Select Item"]
    AdjustmentForm --> AdjustQuantity["Adjust Quantity"]
    AdjustmentForm --> AdjustmentReason["Adjustment Reason"]
    AdjustmentForm --> SaveAdjustment["Save Adjustment"]
    
    %% Basic Reordering System
    InventoryDashboard --> ReorderSection["Reorder Needed"]
    ReorderSection --> ReorderItemsList["Reorder Items List"]
    ReorderItemsList --> MarkAsOrdered["Mark as Ordered"]
    ReorderItemsList --> RecordRestockButton["Record Restock"]
    RecordRestockButton --> RestockForm["Restock Form"]
    RestockForm --> SelectRestockItem["Select Item"]
    RestockForm --> RestockQuantity["Enter Quantity"]
    RestockForm --> RestockDate["Enter Date"]
    RestockForm --> SaveRestock["Save Restock"]
    
    %% Simple Reporting
    InventoryDashboard --> InventoryReports["Inventory Reports"]
    InventoryReports --> UsageTrendsReport["Usage Trends"]
    InventoryReports --> StockStatusReport["Stock Status"]
    InventoryReports --> ExportInventoryData["Export Data"]
    ExportInventoryData --> ExportFormat["Select Format"]
    ExportFormat --> ExportCSV["Export as CSV"]
    ExportFormat --> ExportPDF["Export as PDF"]
    ExportFormat --> ExportExcel["Export as Excel"]
    
    %% Repair-Inventory Integration
    CheckOutForm --> UseParts["Use Parts"]
    UseParts --> SelectPartsForRepair["Select Parts"]
    SelectPartsForRepair --> InventoryUpdate["Auto Update Inventory"]
    
    %% Style Definitions
    classDef primary fill:#2563eb,stroke:#1e40af,color:white
    classDef secondary fill:#3b82f6,stroke:#2563eb,color:white
    classDef decision fill:#dbeafe,stroke:#3b82f6,color:black
    classDef inventory fill:#10b981,stroke:#047857,color:white
    classDef inventoryAction fill:#34d399,stroke:#10b981,color:black
    
    %% Apply Styles
    class Login,Dashboard primary
    class ServiceHub,VehicleCheckin,BillingPayments,VehicleHistory,Settings,VehicleCheckout,Inventory secondary
    class UserType,Components,CheckInOptions,JobFeatures,AdminFeatures,StaffFeatures decision
    class InventoryDashboard,InventoryList,StockLevels,UsageLogging,ReorderSection,InventoryReports inventory
    class AddItem,EditItem,RemoveItem,ManualAdjustment,RecordRestockButton,ExportInventoryData inventoryAction
